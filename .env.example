GHCR_OWNER=your-github-user-or-org
APP_VERSION=dev
COMPOSE_PROFILES=

DOMAIN=assistant.example.com
# Replace placeholder secrets before serving traffic.
INTERNAL_OPENAI_API_KEY=change-me
WEBUI_SECRET_KEY=change-me
POSTGRES_PASSWORD=change-me

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=embeddinggemma

STT_BASE_URL=http://stt-service:8080
STT_MODEL=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_PREWARM_ON_STARTUP=true
STT_TIMEOUT_SECONDS=60
STT_MAX_FILE_BYTES=26214400
STT_MAX_CONCURRENCY=1

VOICE_ENABLED=false
TTS_BASE_URL=http://tts-service:8080
TTS_DEFAULT_VOICE=assistant-default

SEARCH_API_KEY=
SEARCH_BASE_URL=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_BASE_URL=https://api.spotify.com
SPOTIFY_TIMEOUT_SECONDS=5
SPOTIFY_SEARCH_TOP_K=3
