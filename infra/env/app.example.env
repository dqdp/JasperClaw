# agent-api and runtime-adjacent service configuration

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_FAST_CHAT_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=embeddinggemma
MEMORY_ENABLED=false
MEMORY_TOP_K=3
MEMORY_MIN_SCORE=0.35
OLLAMA_TIMEOUT_SECONDS=30
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assistant
POSTGRES_USER=assistant
LOG_LEVEL=INFO

STT_BASE_URL=http://stt-service:8080
STT_MODEL=large-v3
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_TIMEOUT_SECONDS=60
STT_MAX_FILE_BYTES=26214400
STT_MAX_CONCURRENCY=1

VOICE_ENABLED=false
TTS_BASE_URL=http://tts-service:8080
TTS_DEFAULT_VOICE=assistant-default

SEARCH_API_KEY=
SEARCH_BASE_URL=
WEB_SEARCH_ENABLED=false
WEB_SEARCH_TOP_K=3
WEB_SEARCH_TIMEOUT_SECONDS=5

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_BASE_URL=https://api.spotify.com
SPOTIFY_TIMEOUT_SECONDS=5
SPOTIFY_SEARCH_TOP_K=3
