# Telegram ingress smoke configuration for CI-like runs

TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET_TOKEN=ci-webhook-secret
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_BOT_TOKEN=ci-telegram-bot
TELEGRAM_API_BASE_URL=http://telegram-fake:8080
TELEGRAM_ALERT_BOT_TOKEN=ci-telegram-alert-bot
TELEGRAM_ALERT_CHAT_IDS=9001
TELEGRAM_ALERT_WARNING_CHAT_IDS=9002
TELEGRAM_ALERT_CRITICAL_CHAT_IDS=9003
TELEGRAM_ALERT_AUTH_TOKEN=ci-alert-secret
TELEGRAM_ALERT_API_BASE_URL=http://telegram-fake:8080
TELEGRAM_ALERT_SEND_RESOLVED=false

TELEGRAM_REQUEST_TIMEOUT_SECONDS=5
TELEGRAM_POLLING_TIMEOUT_SECONDS=30
TELEGRAM_POLLING_BATCH_SIZE=100
TELEGRAM_RATE_LIMIT_WINDOW_SECONDS=60
TELEGRAM_RATE_LIMIT_PER_CHAT=20
TELEGRAM_RATE_LIMIT_GLOBAL=500
TELEGRAM_MAX_INPUT_CHARS=4000
TELEGRAM_ALLOWED_COMMANDS=/help,/status,/ask
TELEGRAM_DEDUP_WINDOW_SECONDS=3600
TELEGRAM_DEDUP_MAX_EVENTS=1024
TELEGRAM_MAX_REPLY_CHARS=4096

AGENT_API_BASE_URL=http://agent-api:8080
AGENT_API_MODEL=assistant-fast
AGENT_API_KEY=ci-smoke-key
